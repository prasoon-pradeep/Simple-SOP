{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SOP Builder",
  "identifier": "com.pp.sop-builder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SOP Builder",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4MUZCMkQ5MjAyODRCRQpSV1MraEFLU0xmdUJESmxWUXBXdW9pcGhuMy91QnZUbTFMQUFDenhtTU1qUkRxcDZhUXBmOTRTdwo=",
      "endpoints": [
        "https://github.com/prasoon-pradeep/Simple-SOP/releases/latest/download/latest.json"
      ]
    }
  }
}
